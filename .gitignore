# ══════════════════════════════════════════════════════════════════════════════
# .gitignore — Proyecto MIDAS Demo
#
# NOTA: Este .gitignore está configurado para un repositorio de demostración.
#       El proyecto completo incluye exclusiones adicionales para modelos,
#       datasets y configuraciones sensibles.
# ══════════════════════════════════════════════════════════════════════════════

# ── Variables de entorno y secretos ─────────────────────────────────────────────
.env
.env.local
.env.production
.env.staging
*.key
*.pem
secrets/

# ── Python ─────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ── Entornos virtuales ─────────────────────────────────────────────────────────
.venv/
venv/
ENV/
env/
.env/

# ── IDEs y editores ────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Docker ─────────────────────────────────────────────────────────────────────
*.log
.docker/

# ── Logs y bases de datos temporales ───────────────────────────────────────────
logs/
*.log
*.sqlite
*.sqlite3
*.db

# ── Archivos temporales ────────────────────────────────────────────────────────
*.tmp
*.temp
*.bak
*.backup

# ── Streamlit ──────────────────────────────────────────────────────────────────
.streamlit/secrets.toml

# ── Jupyter Notebooks ──────────────────────────────────────────────────────────
.ipynb_checkpoints
*.ipynb

# ── Coverage y testing ─────────────────────────────────────────────────────────
.coverage
.pytest_cache/
htmlcov/
.tox/
.nox/

# ── Documentación generada ─────────────────────────────────────────────────────
docs/_build/
site/

# NOTA PARA EL PROYECTO COMPLETO:
# En el repositorio real se excluyen también:
# models/               # Modelos de ML entrenados
# data/                 # Datasets sintéticos y reales
# training/logs/        # Logs de entrenamiento
# n8n/workflows/        # Workflows configurados
# backups/              # Backups de base de datos
# monitoring/           # Datos de monitoreo