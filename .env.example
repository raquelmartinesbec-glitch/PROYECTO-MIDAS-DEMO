# ══════════════════════════════════════════════════════════════════════════════
# .env.example — Variables de entorno para demostración de Proyecto MIDAS
#
# INSTRUCCIONES:
#   1. Copia este archivo como .env: cp .env.example .env
#   2. Ajusta los valores según tu entorno de evaluación
#   3. NO subas el archivo .env a repositorios públicos
#
# NOTA: Variables básicas para demostración. El proyecto completo incluye
#       configuraciones adicionales de seguridad, monitoring y integración.
# ══════════════════════════════════════════════════════════════════════════════

# ── Configuración de Base de Datos (Demo) ──────────────────────────────────────
POSTGRES_USER=demo_user
POSTGRES_PASSWORD=demo_password_2024
POSTGRES_DB=midas_demo_db

# ── Configuración de la API ────────────────────────────────────────────────────
API_PORT=8000
API_DEBUG=false
DEMO_MODE=true

# ── Configuración del Dashboard ────────────────────────────────────────────────
DASHBOARD_PORT=8501
API_URL=http://midas-api:8000

# ── Configuración de n8n (Automatización) - OPCIONAL ──────────────────────────
# Descomenta si quieres evaluar las funcionalidades de automatización
N8N_PORT=5678
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=demo
N8N_BASIC_AUTH_PASSWORD=midas2024

# ── Configuración de red ───────────────────────────────────────────────────────
NETWORK_NAME=midas_demo_net

# ── Configuración de logging ───────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json

# ══════════════════════════════════════════════════════════════════════════════
# NOTA PARA EVALUADORES:
# 
# Esta configuración de demostración está simplificada para facilitar la
# evaluación del sistema. El proyecto completo incluye:
#
# • Configuración de SSL/TLS para conexiones seguras
# • API keys y tokens de autenticación
# • Configuraciones de integración con Google Calendar
# • Variables de notificación por email  
# • Configuraciones de backup automático
# • Settings de monitoreo y alertas
# • Configuraciones específicas de producción
# ══════════════════════════════════════════════════════════════════════════════